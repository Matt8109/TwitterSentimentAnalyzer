@using System.Web.Optimization
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Oclumen :: Blackfathom</title>
    @Styles.Render("~/Content/flat-ui/css/bootstrap.css")
    @Styles.Render("~/Content/flat-ui/css/flat-ui.css")
    @Styles.Render("/Content/SimpleGrid.css")

    <script src="https://ajax.googleapis.com/ajax/libs/jquery/1.8.2/jquery.min.js"> </script>
</head>
<body>
    <div class="grid">
        <header class="col-1-1">
            <div class="navbar navbar-inverse">
                <div class="navbar-inner">
                    <div class="container">
                        <div class="nav-collapse collapse">
                            <ul class="nav">
                                <li>
                                    <a href="~/" title ="Realtime Tweet Classification">Realtime</a>
                                </li>
                                <li class="nav">
                                    <a href="~/Statistics" title="System Statistics">Statistics</a>
                                </li>
                                <li><a href="~/About" title="About Oclumen">About</a></li>
                            </ul>
                        </div>
                        <!--/.nav-collapse -->
                    </div>
                </div>
            </div>
        </header>
    </div>

    <div id="toolbar">
        <nav id="mainNav">
        </nav>

    </div>

    <div id="bodyContent">
        @RenderBody()
    </div>

    @RenderSection("scripts", required: false)
    @Scripts.Render("~/bundles/flat-ui")

    @*    <footer>
        Build: @HttpContext.Current.Application["BuildTime"]
    </footer>*@
</body>
</html>

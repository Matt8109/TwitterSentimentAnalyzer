    <_SavePWD>True</_SavePWD>
    <PublishDatabaseSettings>
      <Objects xmlns="">
        <ObjectGroup Name="OclumenContext" Order="1" Enabled="False">
          <Destination Path="Data Source=db.oclumen.blackfathom.com;Initial Catalog=Oclumen;User ID=oclumen_crawler;Password=FrubataCeBut7Ag2" />
